name: Build APK

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.10'

      - name: Install dependencies
        run: |
          sudo apt-get update
          sudo apt-get install -y git zip unzip openjdk-17-jdk python3-pip libffi-dev libssl-dev build-essential zlib1g-dev
          pip install buildozer==1.5.0 cython

      - name: Rename app file
        run: cp classroom_groups-6.py main.py 2>/dev/null || cp classroom_groups*.py main.py

      - name: Create buildozer.spec
        run: |
          cat > buildozer.spec << 'SPEC'
          [app]
          title = Keep Moving
          package.name = keepmoving
          package.domain = org.classroom
          source.dir = .
          source.include_exts = py
          version = 1.0
          requirements = python3,kivy==2.2.1
          orientation = portrait
          android.permissions = INTERNET,VIBRATE,ACCESS_WIFI_STATE,CHANGE_WIFI_STATE
          android.minapi = 21
          android.api = 33
          android.ndk = 25b
          android.accept_sdk_license = True
          [buildozer]
          log_level = 2
          SPEC

      - name: Build APK
        run: yes | buildozer android debug 2>&1

      - name: Upload APK
        uses: actions/upload-artifact@v3
        with:
          name: KeepMoving-APK
          path: bin/*.apk
